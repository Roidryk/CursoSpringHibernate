pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "imgpaises:latest"
        CONTAINER_NAME = "paises"
        URL_PROJECT = "C:/CursoSpringHibernate2026Tarde/ProyectosEclipse/51_MicroServicioDockerConJenkins"
    }

    stages {
        stage('Build JAR') {
            steps {
                dir("$URL_PROJECT"){
                    bat 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Stop & Remove Container') {
            steps {
                bat "@docker rm -f %CONTAINER_NAME% 2>nul"
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("$URL_PROJECT") {
                    script {
                        bat "@docker rmi %DOCKER_IMAGE% 2>nul || exit 0"
                        bat "@docker build -t %DOCKER_IMAGE% ."
                    }
                }
            }
        }

        stage('Run Container') {
            steps {
                bat "@docker run -d --name %CONTAINER_NAME% -p 9000:8500 %DOCKER_IMAGE%"
            }
        }
    }
}


